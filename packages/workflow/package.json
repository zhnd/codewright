{
  "name": "@codewright/workflow",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./workflows": {
      "types": "./src/workflows/index.ts",
      "development": "./src/workflows/index.ts",
      "import": "./dist/workflows/index.js"
    },
    "./activities": {
      "types": "./src/activities/index.ts",
      "development": "./src/activities/index.ts",
      "import": "./dist/activities/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@temporalio/activity": "^1.17.0",
    "@temporalio/client": "^1.17.0",
    "@temporalio/common": "^1.17.0",
    "@temporalio/workflow": "^1.17.0",
    "@codewright/agent-runtime": "workspace:*",
    "@codewright/database": "workspace:*",
    "@codewright/solver": "workspace:*",
    "@codewright/domain": "workspace:*",
    "@codewright/githost": "workspace:*",
    "@codewright/sandbox": "workspace:*",
    "@codewright/shared": "workspace:*"
  }
