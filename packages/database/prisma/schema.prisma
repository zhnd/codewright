generator client {
  provider = "prisma-client"
  output   = "../src/__generated__/prisma"
}

generator pothos {
  provider          = "prisma-pothos-types"
  prismaUtils       = true
  generateDatamodel = true
  output            = "../src/__generated__/pothos-prisma-types.ts"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────────────

enum AuthMethod {
  NONE
  TOKEN
  SSH_KEY
}

enum AuthProvider {
  GITHUB
  GITLAB
  GITEA
  CNB
}

enum TaskType {
  ANALYZE_REPOSITORY
  RESOLVE_DEFECT
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskEventKind {
  STAGE
  REVIEW
}

enum TaskEventStatus {
  RUNNING
  AWAITING
  COMPLETED
  REJECTED
  FAILED
  SKIPPED
}

enum TaskStageKey {
  ANALYSIS
  REPRODUCE
  IMPLEMENT
  FILTER
  CRITIC
  PR
}

enum ExecutionStatus {
  RUNNING
  SUCCESS
  FAILED
  CANCELLED
}

enum StageStatus {
  PENDING
  RUNNING
  AWAITING
  COMPLETED
  FAILED
  SKIPPED
}

enum AgentInvocationStatus {
  RUNNING
  SUCCESS
  ERROR
}

// ── Auth (better-auth) ─────────────────────────────────────────

model User {
  id                       String                    @id
  name                     String
  email                    String
  emailVerified            Boolean                   @default(false)
  image                    String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  sessions                 Session[]
  accounts                 Account[]
  projects                 Project[]
  tasks                    Task[]
  taskReviews              TaskEvent[]               @relation("decidedBy")
  tapdCredential           TapdCredential?
  tapdWorkspaceProjectMaps TapdWorkspaceProjectMap[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ── Projects ───────────────────────────────────────────────────

model Project {
  id                   String       @id @default(cuid())
  name                 String
  repositoryUrl        String
  authMethod           AuthMethod   @default(NONE)
  authProvider         AuthProvider @default(GITHUB)
  encryptedCredentials String?
  // Structured per-workflow config. Shape discriminated by key at read time.
  // e.g. { preview: { command, port, readyPattern } }
  workflowConfig       Json?
  // Legacy preview fields — superseded by workflowConfig.preview; kept
  // nullable for one release so running code can still read them.
  previewCommand       String?
  previewPort          Int?
  previewReadyPattern  String?
  userId               String
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks                Task[]
  tapdMappings         TapdWorkspaceProjectMap[]
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([userId])
  @@map("project")
}

// ── Tapd integration ───────────────────────────────────────────
//
// One credential row per user (Tapd accounts are personal). The
// encrypted secret is always a Tapd Personal Access Token, encrypted
// with the same AES-256-GCM key as Project credentials.

model TapdCredential {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  encryptedSecret String
  /// Tapd login handle (UserWorkspace.user) discovered server-side at
  /// save time and cached. Used as `current_owner` filter on /bugs so
  /// the form never has to ask the user for it.
  tapdNick        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("tapd_credential")
}

// Each (user, Tapd workspace) maps to exactly one Codewright Project. We
// store this so the Tapd inbox knows which Project to dispatch a
// resolve-defect workflow against without the user picking on each
// trigger.
model TapdWorkspaceProjectMap {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  projectId   String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, workspaceId])
  @@index([projectId])
  @@map("tapd_workspace_project_map")
}

// ── Tasks ──────────────────────────────────────────────────────
//
// Task is slim metadata only: who, what, when, lifecycle status. No per-stage
// state lives here — that's all in TaskEvent. The server resolver derives
// the display view (current stage, awaiting flag, stage list with attempts +
// reviews) from grouping events by stageKey.

model Task {
  id            String     @id @default(cuid())
  type          TaskType   @default(ANALYZE_REPOSITORY)
  status        TaskStatus @default(PENDING)

  // Original request payload for this task (e.g. {defectDescription}).
  input         Json

  // How the task was triggered: 'manual' | 'webhook' | 'cron' | ...
  triggerSource String     @default("manual")

  // Terminal-only error text (set when status → FAILED / CANCELLED).
  error         String?

  userId        String?
  user          User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  projectId     String?
  project       Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Temporal workflow id, set after workflow.start. Unique because each
  // task corresponds to at most one running workflow.
  workflowId    String?    @unique

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  startedAt     DateTime?  // first transition into RUNNING
  completedAt   DateTime?  // first transition into a terminal status

  events        TaskEvent[]

  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([createdAt])
  @@map("task")
}

// One row per (stage, attempt) for STAGE kind, or per (stage, attempt) of
// HITL submission for REVIEW kind. Self-contained — input/output captures
// what went in and came out so the row is debuggable in isolation.
//
// Lifecycle:
//   STAGE: RUNNING → (AWAITING) → COMPLETED | REJECTED | FAILED | SKIPPED
//   REVIEW: inserted at COMPLETED (the decision is the event)
//
// See plan: /Users/void/.claude/plans/cnb-cool-cnb-mellow-parnas.md
model TaskEvent {
  id            String          @id @default(cuid())
  taskId        String
  task          Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)

  kind          TaskEventKind
  stageKey      TaskStageKey
  attemptNumber Int             @default(1)

  status        TaskEventStatus @default(RUNNING)
  input         Json?
  output        Json?
  error         String?

  // Reviewer userId — non-null iff kind = REVIEW.
  decidedBy     String?
  decidedByUser User?           @relation("decidedBy", fields: [decidedBy], references: [id], onDelete: SetNull)

  startedAt        DateTime          @default(now())
  endedAt          DateTime?
  durationMs       Int?

  // Agent cost rollup for this stage attempt (sum across the stage's agent
  // runs). Written when the stage completes; the task hero sums these.
  costUsd          Float?
  inputTokens      Int?
  outputTokens     Int?
  model            String?

  // OTel stage span — root of this attempt's agent-run/tool subtree.
  // Each AgentMessageLog row's invocation span (parentSpanId) is a child
  // of this, reconstructed via the taskEventId FK. Null for pre-migration
  // events.
  spanId           String?

  // The streamed agent message log for this stage attempt (append-only).
  messageLog       AgentMessageLog[]

  @@unique([taskId, kind, stageKey, attemptNumber])
  @@index([taskId, startedAt])
  @@index([taskId, status])
  @@map("task_event")
}

// ── Layer 0: Workflow registry ────────────────────────────────

model WorkflowDefinition {
  id          String          @id @default(cuid())
  kind        String          @unique
  displayName String
  version     Int             @default(1)
  stages      WorkflowStage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("workflow_definition")
}

model WorkflowStage {
  id                   String             @id @default(cuid())
  workflowDefinitionId String
  workflowDefinition   WorkflowDefinition @relation(fields: [workflowDefinitionId], references: [id], onDelete: Cascade)
  name                 String
  label                String
  order                Int
  allowsRetry          Boolean            @default(true)
  allowsHitl           Boolean            @default(false)
  config               Json?

  @@unique([workflowDefinitionId, name])
  @@index([workflowDefinitionId, order])
  @@map("workflow_stage")
}

// Append-only agent message log: one row per streamed agent message
// (provider-neutral, OTel-GenAI-shaped). Written incrementally *during*
// the agent run (not just at activity end) so the web can follow + replay
// the agent live. The sole agent-observability record alongside TaskEvent
// (stage + status + cost).
model AgentMessageLog {
  id                String    @id @default(cuid())
  // Global monotonic read cursor (insertion order). Clients page/stream by
  // (taskId, cursor > lastSeen) — no cross-activity coordination needed.
  cursor            BigInt    @default(autoincrement())

  // Anchored to the STAGE TaskEvent this run belongs to.
  taskEventId       String
  taskEvent         TaskEvent @relation(fields: [taskEventId], references: [id], onDelete: Cascade)
  // Denormalized for the NOTIFY trigger + per-task subscription fan-out,
  // avoiding a join in the trigger / subscription query.
  taskId            String
  // Per-task OTel trace id (= traceIdForTask(taskId), stable across all
  // stages/runs). Lets every message-log row of a task be correlated into
  // one trace: traceId → TaskEvent.spanId → parentSpanId → spanId.
  traceId           String

  // Temporal activityId of the agent run + monotonic seq within one
  // attempt. Together they idempotently dedupe at-least-once streamed
  // writes (and a retry deletes-and-rewrites by activityId).
  activityId        String
  seq               Int

  // Provider-neutral event kind: message | reasoning | tool_call |
  // tool_result | usage | error.
  kind              String
  role              String?
  textContent       String?
  textTruncatedAt   Int?
  toolUseId         String?
  toolName          String?
  payload           Json?
  payloadTruncatedAt Int?
  // Reserved: pointer to large body offloaded to object storage. Null for
  // now (inline truncation only).
  blobRef           String?

  spanId            String    @unique
  parentSpanId      String
  createdAt         DateTime  @default(now())

  @@unique([activityId, seq])
  @@index([taskId, cursor])
  @@index([taskEventId])
  @@index([traceId])
  @@map("agent_message_log")
}

// ── Model pricing ─────────────────────────────────────────────
//
// Per-model token prices used to derive run cost from token counts (the
// SDK-reported figure is wrong for custom/gateway models). Starts empty;
// rows are populated on demand: when a run uses a model with no row here,
// the pricing service fetches it from a public price API (LiteLLM) and
// upserts it. The in-code MODEL_PRICING map in @codewright/domain remains
// the last-resort fallback when both this table and the remote fetch miss.
model ModelPrice {
  id           String   @id @default(cuid())
  // Model identifier as configured/used (e.g. "claude-sonnet-4-6"). Cost
  // lookup is exact-then-longest-prefix, so dated/"[1m]" variants resolve.
  model        String   @unique
  // USD per 1M tokens (matches @codewright/domain ModelPricing).
  inputPer1M   Float
  outputPer1M  Float
  // Where the row came from: "litellm" (remote fetch) etc. Null = unknown.
  source       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("model_price")
}
