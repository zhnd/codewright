{
  "name": "@codewright/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --conditions development --env-file=../../.env src/server.ts",
    "check": "biome check",
    "check-types": "tsc --noEmit",
    "start": "node dist/server",
    "clean": "node ../../scripts/rm.mjs dist",
    "build": "tsc -b .",
    "generate": "pnpm tsx --conditions development scripts/export-schema.ts",
    "reconcile-tasks": "tsx --conditions development --env-file=../../.env scripts/reconcile-tasks.ts",
    "start:migrate:prod": "pnpm --filter @codewright/database migrate:deploy && pnpm start"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/fastify": "^3.1.0",
    "@better-auth/prisma-adapter": "^1.6.9",
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "@pothos/core": "^4.12.0",
    "@pothos/plugin-dataloader": "^4.4.3",
    "@pothos/plugin-prisma": "catalog:",
    "@pothos/plugin-relay": "^4.7.0",
    "@pothos/plugin-scope-auth": "^4.1.6",
    "@pothos/plugin-simple-objects": "^4.1.3",
    "@codewright/database": "workspace:*",
    "@codewright/domain": "workspace:*",
    "@codewright/githost": "workspace:*",
    "@codewright/shared": "workspace:*",
    "@codewright/workflow": "workspace:*",
    "@types/ws": "^8.18.1",
    "better-auth": "catalog:",
    "fastify": "^5.8.5",
    "graphql": "catalog:",
    "graphql-scalars": "^1.25.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-ws": "catalog:",
    "pg": "catalog:",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "catalog:",
    "tsx": "catalog:"
  }
}
